<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Calculator Suite" parallel="classes" thread-count="4">

    <test name="Calculator Tests">

        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>

        <packages>
            <package name="tests.arithmetic"/>
            <package name="tests.math"/>
            <package name="tests.trigonometry"/>
            <package name="tests.validation"/>
        </packages>

    </test>

</suite>